# -----------------------------
# PostgreSQL
# -----------------------------
POSTGRES_USER=event_tracker
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=event_tracker

DATABASE_URL=postgresql+asyncpg://event_tracker:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/event_tracker
DATABASE_URL_SYNC=postgresql://event_tracker:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/event_tracker
TEST_DATABASE_URL=postgresql+asyncpg://event_tracker:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/event_tracker_test

# -----------------------------
# Redis
# -----------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------
# JWT
# -----------------------------
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------
# First Admin (run seed command once)
# -----------------------------
FIRST_ADMIN_EMAIL=admin@yourdomain.com
FIRST_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# -----------------------------
# OAuth
# -----------------------------
FACEBOOK_CLIENT_ID=CHANGE_ME_FACEBOOK_CLIENT_ID
FACEBOOK_CLIENT_SECRET=CHANGE_ME_FACEBOOK_CLIENT_SECRET
INSTAGRAM_CLIENT_ID=CHANGE_ME_INSTAGRAM_CLIENT_ID
INSTAGRAM_CLIENT_SECRET=CHANGE_ME_INSTAGRAM_CLIENT_SECRET
OAUTH_REDIRECT_BASE_URL=https://yourdomain.com/api/v1/auth/oauth

# -----------------------------
# Email
# -----------------------------
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
EMAIL_FROM=noreply@yourdomain.com
EMAIL_ENABLED=true

# -----------------------------
# Web Push
# -----------------------------
VAPID_PRIVATE_KEY=CHANGE_ME_VAPID_PRIVATE_KEY
VAPID_PUBLIC_KEY=CHANGE_ME_VAPID_PUBLIC_KEY
VAPID_CLAIMS_EMAIL=mailto:admin@yourdomain.com

# -----------------------------
# CORS / App
# -----------------------------
CORS_ORIGINS=["https://yourdomain.com"]
APP_ENV=production
APP_DEBUG=false
APP_ENABLE_DOCS=false
APP_ALLOWED_HOSTS=["yourdomain.com","www.yourdomain.com"]
