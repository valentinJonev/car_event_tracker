# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/event_tracker
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/event_tracker
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/event_tracker_test

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# First Admin (used by seed-admin command)
FIRST_ADMIN_EMAIL=admin@carevents.com
FIRST_ADMIN_PASSWORD=admin123change-me

# OAuth2 Placeholders
FACEBOOK_CLIENT_ID=placeholder-facebook-client-id
FACEBOOK_CLIENT_SECRET=placeholder-facebook-client-secret
INSTAGRAM_CLIENT_ID=placeholder-instagram-client-id
INSTAGRAM_CLIENT_SECRET=placeholder-instagram-client-secret
OAUTH_REDIRECT_BASE_URL=http://localhost/api/v1/auth/oauth

# Email (console output in dev)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@carevents.com
SMTP_PASSWORD=placeholder-smtp-password
EMAIL_FROM=noreply@carevents.com
EMAIL_ENABLED=false

# Web Push (generate with: python -c "from pywebpush import webpush; from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_pem()); print(v.public_key)")
VAPID_PRIVATE_KEY=placeholder-vapid-private-key
VAPID_PUBLIC_KEY=placeholder-vapid-public-key
VAPID_CLAIMS_EMAIL=mailto:admin@carevents.com

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost"]

# App
APP_ENV=development
APP_DEBUG=true
